# ===========================================================
# .gitignore — Shift Roster
# ===========================================================

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Distribution / packaging ---
.Python
build/
dist/
*.egg-info/
*.egg

# --- Environment / secrets ---
.env
.env.local
.env.*.local

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-*
.DS_Store

# --- Logs ---
*.log
logs/

# --- Local database files (dev / test) ---
*.db
*.sqlite
*.sqlite3

# --- Node / frontend tooling ---
node_modules/
frontend/dist/
.parcel-cache/

# --- Docker volumes & state ---
.docker/
postgres_data/

# --- Project-local files (not for the repo) ---
.kkey/
Phase*
build_start.sh
git_add_commit_push.sh
agent_memory.jsonl
ai_agent_config.json
ai_agent_session.json

