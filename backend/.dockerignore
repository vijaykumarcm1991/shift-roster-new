# ===========================================================
# .dockerignore — backend image
# Everything below is excluded from the Docker build context
# to keep the image small, secure, and fast to build.
# NOTE: this file lives inside the build context (./backend),
# so the Dockerfile at backend/Dockerfile MUST be included.
# ===========================================================

# --- Version control ---
.git/
.gitignore

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Tests (not needed in production image) ---
tests/
pytest.ini
pyproject.toml
setup.cfg
setup.py
tox.ini

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-*
.DS_Store

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Database files (local dev only) ---
*.db
*.sqlite
*.sqlite3

# --- Logs ---
*.log
logs/

# --- Docker orchestration (not part of the image) ---
docker-compose.yml
docker-compose.*.yml
.docker/

# --- Docs / meta ---
README.md
LICENSE
CHANGELOG.md
.gitattributes

# --- Project-local files (project root, not relevant to backend image) ---
Phase*
build_start.sh
git_add_commit_push.sh
.kkey/
agent_memory.jsonl
ai_agent_config.json
ai_agent_session.json
ai_agent.log

# --- Frontend (served by nginx, not the backend) ---
frontend/
docker/
