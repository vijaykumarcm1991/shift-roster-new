# ===========================================================
# .env.example - Shift Roster
# Copy this file to .env and fill in real values.
# .env is gitignored; this template is committed.
# ===========================================================

# --- Application ---
APP_NAME=Shift Roster
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=UTC

# --- Backend server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Security ---
# Generate with: openssl rand -hex 32
# In production APP_ENV=production, the default "change-me" is REJECTED.
SECRET_KEY=change-me-please-generate-a-real-one-with-openssl-rand-hex-32

# JSON-formatted list. CORS is only used when frontend and backend are on
# different origins (e.g. Vite dev server). Leave empty when serving
# frontend via the same nginx as the API.
# BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Database ---
# These four build DATABASE_URL automatically. Override DATABASE_URL
# directly only if you point at an external Postgres instance.
POSTGRES_USER=shiftroster
POSTGRES_PASSWORD=shiftroster
POSTGRES_DB=shiftroster
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL=postgresql+psycopg2://shiftroster:shiftroster@postgres:5432/shiftroster
